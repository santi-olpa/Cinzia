# =========================================================
#  Variables de entorno requeridas por la function `cinzi`
#  NO usar este archivo para valores reales — solo plantilla
#  Las claves reales se configuran en Netlify Dashboard
# =========================================================

# Anthropic API key (OBLIGATORIA)
# Sacar de: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Origen permitido para CORS (recomendado en producción)
# Ejemplo: https://cinzia-rental.netlify.app
# Si se deja en '*', cualquier dominio puede llamar al endpoint
ALLOWED_ORIGIN=*

# Modelo de Claude a usar (opcional)
# Opciones:
#   claude-haiku-4-5-20251001  (default · más barato y rápido)
#   claude-sonnet-4-6          (más capaz, ~5x más caro)
CINZI_MODEL=claude-haiku-4-5-20251001
