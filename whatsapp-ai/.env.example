# WhatsApp Cloud API — conseguir en Meta Developers > tu app > WhatsApp > Inicio
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=cinzia_webhook_verify

# Anthropic — console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# OpenAI (para Whisper, transcripción de audios) — platform.openai.com > API Keys
OPENAI_API_KEY=

# Números de escalado en formato internacional (sin + ni espacios)
# Ejemplo Argentina: 5491155551234 (54 + 9 + código de área + número)
ESCALATION_JORGE_NUMBER=
ESCALATION_PAULO_NUMBER=

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./cinzia.db
